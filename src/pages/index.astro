---
import fs from 'node:fs';
import path from 'node:path';

const contentDir = path.join(process.cwd(), 'src/content');

function parseYaml(filePath: string): Record<string, any> {
  try {
    const raw = fs.readFileSync(filePath, 'utf-8');
    const result: Record<string, any> = {};
    let inArray = false;
    let arrayKey = '';
    let arrayItems: string[] = [];

    for (const line of raw.split('\n')) {
      if (line.startsWith('  - ') && inArray) {
        arrayItems.push(line.slice(4).replace(/^"|"$/g, ''));
        continue;
      }
      if (inArray) { result[arrayKey] = arrayItems; inArray = false; arrayItems = []; }
      const m = line.match(/^(\w+):\s*(.*)$/);
      if (m) {
        const val = m[2].replace(/^"|"$/g, '');
        if (val === '') { inArray = true; arrayKey = m[1]; arrayItems = []; }
        else { result[m[1]] = val; }
      }
    }
    if (inArray) result[arrayKey] = arrayItems;
    return result;
  } catch { return {}; }
}

function readCollection(name: string) {
  const dir = path.join(contentDir, name);
  try {
    return fs.readdirSync(dir)
      .filter((f: string) => f.endsWith('.yaml'))
      .map((f: string) => parseYaml(path.join(dir, f)))
      .sort((a, b) => (Number(a.order) || 0) - (Number(b.order) || 0));
  } catch { return []; }
}

const hero = parseYaml(path.join(contentDir, 'hero/index.yaml'));
const settings = parseYaml(path.join(contentDir, 'settings/index.yaml'));
const reviews = readCollection('reviews');
const faqItems = readCollection('faq');

const phone = settings.phone || '05 61 73 86 07';
const phoneHref = 'tel:' + phone.replace(/\s/g, '');

function initials(name: string) {
  return name.split(' ').map(w => w[0]).join('').toUpperCase();
}
