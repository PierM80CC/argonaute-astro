---
import fs from 'node:fs';
import path from 'node:path';
import yaml from 'js-yaml';
import '../styles/style.css';

const contentDir = path.join(process.cwd(), 'src/content');

function loadYaml(filePath: string): Record<string, any> {
  try {
    return yaml.load(fs.readFileSync(filePath, 'utf-8')) as Record<string, any> || {};
  } catch (e) {
    console.error(`Failed to parse ${filePath}:`, e);
    return {};
  }
}

function readCollection(name: string) {
  const dir = path.join(contentDir, name);
  try {
    return fs.readdirSync(dir)
      .filter((f: string) => f.endsWith('.yaml'))
      .map((f: string) => loadYaml(path.join(dir, f)))
      .sort((a, b) => (Number(a.order) || 0) - (Number(b.order) || 0));
  } catch (e) {
    console.error(`Failed to read collection ${name}:`, e);
    return [];
  }
}

const hero = loadYaml(path.join(contentDir, 'hero/index.yaml'));
const settings = loadYaml(path.join(contentDir, 'settings/index.yaml'));
const reviews = readCollection('reviews');
const faqItems = readCollection('faq');
const permits = readCollection('permits');

const phone = settings.phone || '05 61 73 86 07';
const phoneHref = 'tel:' + phone.replace(/\s/g, '');
const year = new Date().getFullYear();

function initials(name: string) {
  return name.split(' ').map((w: string) => w[0]).join('').toUpperCase();
}

const permitImages: Record<string, string> = {
  'Permis Côtier': '/images/cotier.jpg',
  'Permis Fluvial': '/images/fluvial.jpg',
  'Extension Hauturière': '/images/hauturier.jpg',
};
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Permis Bateau Toulouse | L'Argonaute - Bateau-École depuis 1979</title>
