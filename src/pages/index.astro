      <a href="#faq" class="nav__link">FAQ</a>
      <a href={phoneHref} class="nav__phone"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg> {phone}</a>
      <a href="#contact" class="btn btn--primary nav__cta">S'inscrire</a>
    </div>
    <button class="nav__burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
  </div>
</nav>

<div class="nav__overlay" id="navOverlay">
  <a href="#permis">Nos permis</a><a href="#methode">Notre méthode</a><a href="#avis">Avis</a><a href="#faq">FAQ</a><a href={phoneHref}>{phone}</a>
</div>

<section class="hero" id="hero">
  <div class="hero__media"><img src={hero.image || '/images/hero.jpg'} alt="Bateau à moteur naviguant sous ciel bleu" fetchpriority="high"></div>
  <div class="hero__overlay"></div>
  <div class="hero__grain"></div>
  <div class="container">
    <div class="hero__content">
      <div class="hero__badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg> {hero.badge}</div>
      <h1 class="hero__title">Votre <span class="gradient-text">permis bateau</span><br>à Toulouse</h1>
      <p class="hero__sub">{hero.subtitle}</p>
      <div class="hero__stats">
        <div class="hero__pill"><span class="hero__pill-num">99%</span><span class="hero__pill-label">de réussite</span></div>
        <div class="hero__pill"><span class="hero__pill-num">45+</span><span class="hero__pill-label">ans d'expertise</span></div>
        <div class="hero__pill"><span class="hero__pill-num">4.8/5</span><span class="hero__pill-label">avis Google</span></div>
      </div>
      <div class="hero__actions">
        <a href="#permis" class="btn btn--primary">{hero.cta_text || 'Découvrir nos formations'} <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"/></svg></a>
        <a href={phoneHref} class="btn btn--ghost">Nous appeler</a>
      </div>
    </div>
  </div>
  <div class="hero__scroll"><span>Scroll</span><div class="hero__scroll-line"></div></div>
  <div class="hero__wave"><svg viewBox="0 0 1440 100" fill="none" preserveAspectRatio="none"><path d="M0 40C120 70 240 85 360 78C480 71 600 42 720 30C840 18 960 22 1080 35C1200 48 1320 70 1380 81L1440 92V100H0V40Z" fill="#f8f7f4"/></svg></div>
</section>

<div class="trust">
  <div class="container">
    <div class="trust__grid">
      <div class="trust__item"><div class="trust__icon-circle"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div><div class="trust__text"><div class="trust__num">4.8<span>/5</span></div><div class="trust__label">Avis Google</div><div class="trust__sub">+200 avis vérifiés</div></div></div>
      <div class="trust__item"><div class="trust__icon-circle trust__icon-circle--cyan"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div><div class="trust__text"><div class="trust__num">99<span>%</span></div><div class="trust__label">Taux de réussite</div><div class="trust__sub">Au 1er passage</div></div></div>
      <div class="trust__item"><div class="trust__icon-circle trust__icon-circle--azure"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg></div><div class="trust__text"><div class="trust__num">45<span>+</span></div><div class="trust__label">Ans d'expérience</div><div class="trust__sub">Bateau-école depuis 1979</div></div></div>
      <div class="trust__item"><div class="trust__icon-circle trust__icon-circle--coral"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg></div><div class="trust__text"><div class="trust__num">3x</div><div class="trust__label">Paiement sans frais</div><div class="trust__sub">CB, chèque, espèces</div></div></div>
    </div>
  </div>
</div>

<!-- PERMIS (dynamique depuis CMS) -->
<section class="section" id="permis">
  <div class="container">
    <div class="section__header"><div class="section__tag">Nos formations</div><h2>Choisissez votre permis</h2><p>Des formations complètes, encadrées par des professionnels du nautisme. Tout est inclus&nbsp;: cours, pratique et supports.</p></div>
    <div class="bento stagger">
      {permits.map((p, i) => {
        const isFeatured = i === 0;
        const img = permitImages[p.name] || '/images/cotier.jpg';
        const badgeClass = i === permits.length - 1 ? 'bento__tag bento__tag--coral' : 'bento__tag';
        return (
          <div class={`bento__card reveal ${isFeatured ? 'bento__card--featured' : ''}`}>
            <div class="bento__img">
              <img src={img} alt={p.name} loading="lazy">
              {p.badge && <span class={badgeClass}>{p.badge}</span>}
            </div>
            <div class="bento__body">
              <h3 class="bento__name">{p.name}</h3>
              <p class="bento__desc">{p.description}</p>
              <div class="bento__meta">
                {(p.features || []).map((f: string) => (
                  <span class="bento__meta-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> {f}</span>
                ))}
              </div>
              <div class="bento__footer">
                <div class="bento__price">{p.price}</div>
                <a href="#contact" class="btn btn--cyan">S'inscrire</a>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<section class="immersive">
  <div class="immersive__bg"><img src="/images/immersive.jpg" alt="Eau turquoise" loading="lazy"></div>
  <div class="container"><div class="immersive__content"><div class="immersive__grid">
    <div class="immersive__left"><div class="section__tag">Pourquoi le permis bateau</div><h2>Ouvrez-vous les portes de la mer</h2><p>Le permis bateau, c'est la liberté de prendre la barre, d'explorer des criques inaccessibles, de vivre des moments uniques sur l'eau.</p>
      <div class="reveal">
        <div class="benefit"><div class="benefit__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22c-4 0-8-2-8-6V4l8-2 8 2v12c0 4-4 6-8 6z"/></svg></div><div class="benefit__text"><h4>Louez un bateau partout</h4><p>En France, en Croatie, en Grèce — votre permis est reconnu internationalement.</p></div></div>
        <div class="benefit"><div class="benefit__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg></div><div class="benefit__text"><h4>Explorez l'inaccessible</h4><p>Criques, îles, grottes marines — des lieux que seul un bateau peut atteindre.</p></div></div>
        <div class="benefit"><div class="benefit__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div><div class="benefit__text"><h4>Naviguez en sécurité</h4><p>Maîtrisez les règles, les manoeuvres et les gestes de sécurité essentiels.</p></div></div>
      </div>
    </div>
    <div class="immersive__highlight stagger">
      <div class="highlight-card reveal"><div class="highlight-card__header"><div class="highlight-card__num">99%</div><div class="highlight-card__badge">Vérifié</div></div><div class="highlight-card__label">de réussite au premier passage</div><div class="highlight-card__bar"><div class="highlight-card__bar-fill" style="width:99%"></div></div></div>
      <div class="highlight-card reveal"><div class="highlight-card__header"><div class="highlight-card__num">10 000+</div></div><div class="highlight-card__label">élèves formés depuis 1979</div><div class="highlight-card__detail">45 ans d'expérience, formateurs diplômés d'État</div></div>
      <div class="highlight-card highlight-card--accent reveal"><div class="highlight-card__header"><div class="highlight-card__num">N°1</div><svg class="highlight-card__trophy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg></div><div class="highlight-card__label">bateau-école en Occitanie</div><div class="highlight-card__detail">La référence à Toulouse et dans toute la région</div></div>
    </div>
  </div></div></div>
</section>

<section class="section section--sand" id="methode">
  <div class="container">
    <div class="section__header"><div class="section__tag">Notre méthode</div><h2>Du premier cours au permis en poche</h2><p>Un parcours structuré et accompagné pour obtenir votre permis bateau en toute sérénité.</p></div>
    <div class="timeline stagger">
      <div class="tl-step reveal"><div class="tl-step__dot">1</div><div class="tl-step__content"><h4 class="tl-step__title">Inscription</h4><p class="tl-step__desc">Choisissez votre permis, remplissez le formulaire et envoyez vos pièces justificatives.</p></div></div>
      <div class="tl-step reveal"><div class="tl-step__dot">2</div><div class="tl-step__content"><h4 class="tl-step__title">Cours théoriques</h4><p class="tl-step__desc">12 heures de formation en salle avec nos moniteurs diplômés d'État.</p></div></div>
      <div class="tl-step reveal"><div class="tl-step__dot">3</div><div class="tl-step__content"><h4 class="tl-step__title">Pratique sur le canal</h4><p class="tl-step__desc">Une demi-journée à bord de nos bateaux-école sur le Canal du Midi.</p></div></div>
      <div class="tl-step reveal"><div class="tl-step__dot">4</div><div class="tl-step__content"><h4 class="tl-step__title">Examen</h4><p class="tl-step__desc">QCM de 40 questions + validation pratique. 99% de réussite.</p></div></div>
      <div class="tl-step reveal"><div class="tl-step__dot">✓</div><div class="tl-step__content"><h4 class="tl-step__title">Permis en poche !</h4><p class="tl-step__desc">Attestation immédiate. Permis définitif retiré dans nos locaux sous 1 mois.</p></div></div>
    </div>
  </div>
</section>

<section class="stats">
  <div class="container"><div class="stats__grid">
    <div class="stat reveal" data-target="99" data-suffix="%"><div class="stat__num">0%</div><div class="stat__label">de réussite</div><div class="stat__bar"></div></div>
    <div class="stat reveal" data-target="45" data-suffix="+"><div class="stat__num">0+</div><div class="stat__label">ans d'expérience</div><div class="stat__bar"></div></div>
    <div class="stat reveal" data-target="10000" data-suffix="+"><div class="stat__num">0+</div><div class="stat__label">élèves formés</div><div class="stat__bar"></div></div>
    <div class="stat reveal" data-target="48" data-suffix="/5" data-divide="10"><div class="stat__num">0/5</div><div class="stat__label">avis Google</div><div class="stat__bar"></div></div>
  </div></div>
</section>

<section class="section" id="avis">
  <div class="container">
    <div class="reviews__header">
      <div><div class="section__tag">Avis clients</div><h2>Ce que disent nos élèves</h2></div>
      <div class="reviews__google-card">
